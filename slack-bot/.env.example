# ---- Slack (create a Slack app, enable Socket Mode) ----
SLACK_BOT_TOKEN=xoxb-...        # Bot User OAuth Token (scopes: files:read, chat:write, reactions:write, im:history, channels:history, groups:history)
SLACK_APP_TOKEN=xapp-...        # App-Level Token with connections:write (Socket Mode)

# ---- Anthropic (writes the email copy from your caption + images) ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# ---- Cloudinary (image hosting) ----
CLOUDINARY_CLOUD=your_cloud_name
CLOUDINARY_KEY=your_cloudinary_key
CLOUDINARY_SECRET=__ROTATE_AND_PUT_A_FRESH_SECRET_HERE__

# ---- Klaviyo ----
KLAVIYO_API_KEY=pk_...          # Private API key (scopes: Templates + Campaigns write)
KLAVIYO_LIST_ID=YOUR_LIST_ID          # Audience to target (the "Email List")
KLAVIYO_FROM_EMAIL=you@example.com
KLAVIYO_FROM_LABEL=Rig

# ---- Brand assets (already on Cloudinary) ----
BRAND_HEADER_LOGO=https://res.cloudinary.com/your_cloud_name/image/upload/rig-header-lockup.png
BRAND_MASCOT=https://res.cloudinary.com/your_cloud_name/image/upload/rig-mascot.png
BRAND_SPOTLIGHT_ICON=https://res.cloudinary.com/your_cloud_name/image/upload/spotlight-green.png

# ---- Build script (the generator we already wrote) ----
BUILD_SCRIPT=../email-builder/build_email.py

# Optional: only respond in this channel ID (leave blank to respond in any channel/DM the bot is in)
ALLOWED_CHANNEL=
